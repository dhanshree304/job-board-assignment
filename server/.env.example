PORT=5000
NODE_ENV=development

# MongoDB Atlas (or local) connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/job-board?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed origins for CORS (client URL(s))
CLIENT_ORIGIN=http://localhost:5173

# Max resume upload size in bytes (default 5MB)
MAX_RESUME_SIZE_BYTES=5242880
